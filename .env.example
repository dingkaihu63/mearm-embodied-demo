# ══════════════════════════════════════════════════════════════════════════════
# MeArm 工作台 — 环境变量配置
# 复制此文件为 .env 并修改对应值
# ══════════════════════════════════════════════════════════════════════════════

# ─── LLM 提供者 (二选一) ────────────────────────────────────────────────────
# 方案 A: 本地 Ollama (默认, 无需 API Key)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:7b
# 可选视觉模型: ollama pull llava
# OLLAMA_VISION_MODEL=llava:latest

# 方案 B: 云端 API (设置 LLM_API_KEY 后自动切换, 覆盖 Ollama)
# 支持 DeepSeek, OpenAI, 或其他 OpenAI 兼容 API
# LLM_API_KEY=sk-your-api-key-here
# LLM_API_BASE_URL=https://api.deepseek.com
# LLM_API_MODEL=deepseek-chat

# ─── 云端多模态视觉 (可选) ──────────────────────────────────────────────────
# 用于摄像头画面理解 (图片+文本联合推理)
# 支持 Kimi/Moonshot, GPT-4V, 或其他 OpenAI 兼容多模态 API
# VISION_API_KEY=sk-your-vision-api-key
# VISION_API_BASE_URL=https://api.moonshot.cn/v1
# VISION_API_MODEL=kimi-k2.6
# VISION_API_TEMPERATURE=1.0

# ─── Vosk 模型路径 ──────────────────────────────────────────────────────────
# VOSK_MODEL_EN=models/vosk-model-small-en-us-0.15
# VOSK_MODEL_CN=models/vosk-model-small-cn

# ─── Flask 密钥 ─────────────────────────────────────────────────────────────
# FLASK_SECRET_KEY=

# ─── 串口 ───────────────────────────────────────────────────────────────────
# SERIAL_PORT=COM3
